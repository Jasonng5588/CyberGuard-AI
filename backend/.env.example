# ============================================================
# AI Cyberbullying Detection System - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Database Connection
DATABASE_URL=postgresql://postgres:password@localhost:5432/cyberbullying_db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS - Frontend URL
FRONTEND_URL=http://localhost:3000

# OpenAI API Key (optional - falls back to rule-based if not set)
OPENAI_API_KEY=your-openai-api-key-here

# AI Model Settings
DETECTION_MODEL=martin-ha/toxic-comment-model
USE_OPENAI_CHATBOT=False

# Security
SECRET_KEY=your-secret-key-change-in-production

# App Name
APP_NAME=CyberGuard AI
